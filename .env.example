# Configurazione Server
NODE_ENV=development
PORT=3000

# Configurazione SAP - API Dati Contabili
SAP_BASE_URL=http://sapr3prd.beltramesrl.local:8030
SAP_API_PATH=/sap/bc/zfidata
SAP_TIMEOUT=30000

# Configurazione SAP - API Set (Fase 2)
SAP_SET_API_PATH=/sap/bc/ybreakeven/yset
SAP_SET_TIMEOUT=15000

# Configurazione Set Client Cache
ENABLE_SET_CACHE=true
SET_CACHE_TTL=300000

# Configurazione SQLite
SQLITE_PATH=./data/sap_data.db

# Configurazione Job
JOB_RETRY_ATTEMPTS=3
JOB_TIMEOUT=3600000
ENABLE_SCHEDULER=true

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# AWS S3 (Fase 2 - futuro)
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=sap-data-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
